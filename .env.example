# ============================================================
# SNIPER — Environment Configuration
# Copy this file:  cp .env.example .env
# Then fill in your real credentials.
# ============================================================

# --- API Credentials ---
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789

# --- Model Configuration ---
# sonar          — fast, cheap   (~$0.01/call)  → intraday updates
# sonar-pro      — balanced      (~$0.03/call)  → pre-market & EOD
# sonar-reasoning-pro — deep     (~$0.05/call)  → weekend deep dives
MODEL_BRIEFING=sonar-pro
MODEL_QUICK=sonar
MODEL_DEEP=sonar-reasoning-pro

# --- Search Settings ---
# Options: hour, day, week, month
SEARCH_RECENCY=day
